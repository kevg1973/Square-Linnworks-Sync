# Linnworks credentials — same values as the Easyship project's .env
# Reuse them verbatim. Add to GitHub Actions Secrets, NOT to a local .env.
LINNWORKS_APP_ID=
LINNWORKS_APP_SECRET=
LINNWORKS_TOKEN=

# Square credentials — from developer.squareup.com
# Open your existing app, toggle "Production" at the top, click Credentials
# in the left pane, click "Show" next to Production Access Token.
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=

# Supabase — from your existing project's Settings → API
# Use the SERVICE ROLE key (not anon), since this is server-side and needs
# to write to all sq_* tables.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
